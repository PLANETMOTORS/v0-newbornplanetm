# =============================================================================
# PLANET MOTORS - ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control
#
# Legend:
#   [REQUIRED]  — App will not start without these
#   [OPTIONAL]  — Graceful degradation when missing
#   [CLIENT]    — Exposed to the browser (NEXT_PUBLIC_*)
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED — Supabase (database + auth)
# -----------------------------------------------------------------------------
# [REQUIRED][CLIENT] Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# [REQUIRED][CLIENT] Supabase anonymous/public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# [OPTIONAL] Supabase service role key (server-side admin operations)
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# APPLICATION
# -----------------------------------------------------------------------------
NODE_ENV=development
APP_NAME=planetmotors
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
ADMIN_URL=http://localhost:3002

# [OPTIONAL][CLIENT] Public site URL used for canonical links, emails, etc.
NEXT_PUBLIC_SITE_URL=https://www.planetmotors.ca
# [OPTIONAL][CLIENT] Alias for NEXT_PUBLIC_SITE_URL (legacy)
NEXT_PUBLIC_BASE_URL=https://www.planetmotors.ca

# -----------------------------------------------------------------------------
# DATABASE (Neon PostgreSQL - used by app/api/v1/inventory/homenet)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://planetmotors:password@localhost:5432/planetmotors_dev
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_SSL=false

# Production (Neon serverless):
# DATABASE_URL=postgres://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
# Legacy RDS format:
# DATABASE_URL=postgresql://planetmotors_admin:${DB_PASSWORD}@planetmotors-prod.xxxxx.ca-central-1.rds.amazonaws.com:5432/planetmotors

# -----------------------------------------------------------------------------
# CACHE (Redis - AWS ElastiCache)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_TLS=false

# Production format:
# REDIS_URL=redis://planetmotors-cache.xxxxx.cache.amazonaws.com:6379

# Upstash Redis (used for google-reviews cache and rate limiting)
# Required in production for /api/google-reviews caching and lib/redis.ts helpers
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# -----------------------------------------------------------------------------
# SEARCH (OpenSearch)
# -----------------------------------------------------------------------------
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_INDEX_PREFIX=planetmotors_dev

# Production format:
# OPENSEARCH_URL=https://planetmotors-search.ca-central-1.es.amazonaws.com

# -----------------------------------------------------------------------------
# AWS SERVICES
# -----------------------------------------------------------------------------
AWS_REGION=ca-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# S3 Buckets
S3_BUCKET_VEHICLES=planetmotors-vehicle-images-dev
S3_BUCKET_DOCUMENTS=planetmotors-documents-dev
S3_BUCKET_INSPECTIONS=planetmotors-inspections-dev

# CloudFront
CLOUDFRONT_DISTRIBUTION_ID=
CLOUDFRONT_DOMAIN=cdn.planetmotors.ca

# -----------------------------------------------------------------------------
# AUTHENTICATION
# -----------------------------------------------------------------------------
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# OAuth - Google
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# -----------------------------------------------------------------------------
# PAYMENTS (Stripe)
# -----------------------------------------------------------------------------
# Get keys from https://dashboard.stripe.com/apikeys
# [OPTIONAL][CLIENT] Stripe publishable key (checkout UI)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_PUBLISHABLE_KEY=pk_test_
# [OPTIONAL] Stripe secret key (server-side charges)
STRIPE_SECRET_KEY=sk_test_
# [OPTIONAL] Stripe webhook endpoint signing secret
STRIPE_WEBHOOK_SECRET=whsec_
STRIPE_API_VERSION=2024-12-18
# [OPTIONAL] Enable Canadian pre-authorized debit
STRIPE_ENABLE_ACSS_DEBIT=false

# -----------------------------------------------------------------------------
# CREDIT BUREAUS
# -----------------------------------------------------------------------------
# Equifax Canada
EQUIFAX_API_URL=https://api.sandbox.equifax.ca
EQUIFAX_API_KEY=
EQUIFAX_MEMBER_CODE=

# TransUnion Canada
TRANSUNION_API_URL=https://api.sandbox.transunion.ca
TRANSUNION_API_KEY=
TRANSUNION_SUBSCRIBER_CODE=

# -----------------------------------------------------------------------------
# LENDER INTEGRATIONS (6 Canadian Banks)
# -----------------------------------------------------------------------------
# TD Auto Finance
TD_AUTO_API_URL=https://api.sandbox.td.com/auto-finance
TD_AUTO_API_KEY=
TD_AUTO_DEALER_ID=

# RBC
RBC_API_URL=https://api.sandbox.rbc.com/financing
RBC_API_KEY=

# Scotiabank
SCOTIA_API_URL=https://api.sandbox.scotiabank.com/dealer-finance
SCOTIA_API_KEY=

# BMO
BMO_API_URL=https://api.sandbox.bmo.com/auto
BMO_API_KEY=

# CIBC
CIBC_API_URL=https://api.sandbox.cibc.com/vehicle-financing
CIBC_API_KEY=

# Desjardins
DESJARDINS_API_URL=https://api.sandbox.desjardins.com/auto
DESJARDINS_API_KEY=

# -----------------------------------------------------------------------------
# VEHICLE DATA PROVIDERS
# -----------------------------------------------------------------------------
# Carfax Canada
CARFAX_API_URL=https://api.sandbox.carfax.ca
CARFAX_API_KEY=
CARFAX_DEALER_ID=

# Canadian Black Book
CBB_API_URL=https://api.sandbox.canadianblackbook.com
CBB_API_KEY=

# DataOne (VIN Decoding)
DATAONE_API_URL=https://api.sandbox.dataonesoftware.com
DATAONE_API_KEY=

# -----------------------------------------------------------------------------
# COMMUNICATIONS
# -----------------------------------------------------------------------------
# Twilio (SMS/Voice)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+16475551234
TWILIO_MESSAGING_SERVICE_SID=

# SendGrid (Email - legacy, not actively used)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=hello@planetmotors.ca
SENDGRID_FROM_NAME=PlanetMotors

# Resend (Email - actively used by lib/email.ts for all transactional email)
# [OPTIONAL] Without this, all notification emails are silently skipped
RESEND_API_KEY=
# [OPTIONAL] Legacy alias — checked as fallback (API_KEY_RESEND || RESEND_API_KEY)
API_KEY_RESEND=

# [OPTIONAL] Admin notification recipient
ADMIN_EMAIL=toni@planetmotors.ca
# [OPTIONAL] From address for transactional email
FROM_EMAIL=Planet Motors <notifications@planetmotors.ca>

# HubSpot (CRM)
HUBSPOT_API_KEY=
HUBSPOT_PORTAL_ID=

# -----------------------------------------------------------------------------
# ANALYTICS
# -----------------------------------------------------------------------------
# [OPTIONAL][CLIENT] Google Analytics 4 measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
GA4_MEASUREMENT_ID=G-XXXXXXXXXX
GA4_API_SECRET=

# [OPTIONAL][CLIENT] Google Tag Manager container ID
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# [OPTIONAL][CLIENT] Meta (Facebook) Pixel ID
NEXT_PUBLIC_META_PIXEL_ID=

# FullStory (Session Replay)
FULLSTORY_ORG_ID=

# Optimizely (A/B Testing)
OPTIMIZELY_SDK_KEY=

# -----------------------------------------------------------------------------
# INSURANCE & WARRANTY
# -----------------------------------------------------------------------------
# Sonnet Insurance
SONNET_API_URL=https://api.sandbox.sonnet.ca
SONNET_API_KEY=

# Lubrico Warranty
LUBRICO_API_URL=https://api.sandbox.lubrico.ca
LUBRICO_API_KEY=

# -----------------------------------------------------------------------------
# BANK VERIFICATION (Plaid)
# -----------------------------------------------------------------------------
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# -----------------------------------------------------------------------------
# MONITORING & ALERTS
# -----------------------------------------------------------------------------
# Sentry (Error Tracking)
SENTRY_DSN=

# PagerDuty (Alerting)
PAGERDUTY_API_KEY=

# Slack (Notifications)
SLACK_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# FEATURE FLAGS
# -----------------------------------------------------------------------------
FEATURE_MULTI_LENDER=true
FEATURE_TRADE_IN=true
FEATURE_HOME_DELIVERY=true
FEATURE_EV_BATTERY_REPORT=true
FEATURE_AB_TESTING=true
FEATURE_SESSION_REPLAY=true
FEATURE_INSTANT_OFFER=true

# -----------------------------------------------------------------------------
# RATE LIMITING
# -----------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_FINANCING_MAX=10

# -----------------------------------------------------------------------------
# DELIVERY HUBS
# -----------------------------------------------------------------------------
DEFAULT_HUB_ID=richmond-hill
DEFAULT_HUB_ADDRESS="30 Major Mackenzie E, Richmond Hill, ON L4C 1G7"
FREE_DELIVERY_RADIUS_KM=250

# -----------------------------------------------------------------------------
# SANITY CMS
# -----------------------------------------------------------------------------
# [OPTIONAL][CLIENT] Sanity project ID (defaults to hardcoded value in code)
NEXT_PUBLIC_SANITY_PROJECT_ID=4588vjsz
# [OPTIONAL][CLIENT] Sanity dataset name
NEXT_PUBLIC_SANITY_DATASET=production
# [OPTIONAL] Sanity webhook signature secret (for on-demand revalidation)
SANITY_WEBHOOK_SECRET=
# [OPTIONAL] Sanity API token (for server-side GROQ queries in scripts)
SANITY_API_TOKEN=

# -----------------------------------------------------------------------------
# GOOGLE SERVICES
# -----------------------------------------------------------------------------
# [OPTIONAL][CLIENT] Google Maps embed key (delivery tracking page)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=
# [OPTIONAL] Google Places API key (reviews fetching)
GOOGLE_PLACES_API_KEY=
# [OPTIONAL] Google Place ID for review aggregation
GOOGLE_PLACE_ID=

# -----------------------------------------------------------------------------
# UPSTASH / KV STORE
# -----------------------------------------------------------------------------
# [OPTIONAL] Vercel KV (Upstash) — used by lib/redis.ts for caching
KV_REST_API_URL=
KV_REST_API_TOKEN=
