{
  "name": "planet-motors",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "NODE_OPTIONS='--max-old-space-size=8192' next dev --turbopack",
    "build": "next build && serwist build",
    "analyze": "ANALYZE=true next build",
    "start": "next start",
    "lint": "eslint .",
    "clean": "rm -rf .next node_modules/.cache",
    "review": "coderabbit --agent -t uncommitted",
    "review:all": "coderabbit --agent",
    "review:ui": "coderabbit review --interactive",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "db:types": "pnpm supabase gen types typescript --project-id $(grep NEXT_PUBLIC_SUPABASE_URL .env.local | sed 's|.*//||;s|\\..*||') > types/supabase.ts",
    "typecheck": "tsc --noEmit",
    "typecheck:test": "tsc --noEmit --project tsconfig.test.json",
    "backup:sanity": "npx tsx lib/cms/backup.ts",
    "seed:sanity": "npx tsx scripts/seed-sanity.ts"
  },
