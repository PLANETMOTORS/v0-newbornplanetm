{
  "$schema": "https://imgix.com/schema/source-config.json",
  "name": "planetmotors-vehicles",
  "description": "Planet Motors Vehicle 360 Spin Images - AVIF Optimized",
  "deployment": {
    "type": "s3",
    "bucket": "planetmotors-vehicle-images",
    "region": "us-east-1",
    "prefix": "vehicles/"
  },
  "domains": [
    {
      "domain": "images.planetmotors.com",
      "default": true,
      "ssl": true,
      "customSubdomain": true
    }
  ],
  "defaultParams": {
    "auto": ["format", "compress"],
    "q": 80,
    "fit": "crop",
    "cs": "srgb"
  },
  "presets": {
    "spin-frame": {
      "description": "360 spin viewer frame - optimized for interactive viewing",
      "params": {
        "w": 1200,
        "h": 800,
        "fit": "crop",
        "auto": ["format", "compress"],
        "q": 85,
        "fm": "avif",
        "ch": "Width,DPR"
      }
    },
    "spin-frame-mobile": {
      "description": "360 spin viewer frame for mobile devices",
      "params": {
        "w": 800,
        "h": 533,
        "fit": "crop",
        "auto": ["format", "compress"],
        "q": 80,
        "fm": "avif"
      }
    },
    "spin-frame-thumb": {
      "description": "360 spin viewer thumbnail for preloading",
      "params": {
        "w": 400,
        "h": 267,
        "fit": "crop",
        "auto": ["format", "compress"],
        "q": 60,
        "fm": "avif",
        "blur": 20
      }
    },
    "inventory-card": {
      "description": "Vehicle inventory card image",
      "params": {
        "w": 600,
        "h": 400,
        "fit": "crop",
        "auto": ["format", "compress"],
        "q": 80,
        "fm": "avif"
      }
    },
    "inventory-card-2x": {
      "description": "Vehicle inventory card image for retina displays",
      "params": {
        "w": 1200,
        "h": 800,
        "fit": "crop",
        "auto": ["format", "compress"],
        "q": 75,
        "fm": "avif"
      }
    },
    "hero-image": {
      "description": "Homepage hero vehicle image",
      "params": {
        "w": 1920,
        "h": 1080,
        "fit": "crop",
        "auto": ["format", "compress"],
        "q": 85,
        "fm": "avif"
      }
    },
    "og-image": {
      "description": "Social media Open Graph image",
      "params": {
        "w": 1200,
        "h": 630,
        "fit": "crop",
        "auto": ["format"],
        "q": 90,
        "fm": "jpg"
      }
    }
  },
  "caching": {
    "ttlBrowser": 86400,
    "ttlEdge": 2592000,
    "staleWhileRevalidate": 604800,
    "staleIfError": 86400
  },
  "security": {
    "secureUrlToken": "${IMGIX_SECURE_TOKEN}",
    "enableSecureUrls": false,
    "allowedReferrers": [
      "planetmotors.com",
      "*.planetmotors.com",
      "*.vercel.app",
      "localhost:3000"
    ]
  },
  "imageProcessing": {
    "defaultFormat": "avif",
    "formatFallback": ["webp", "jpg"],
    "maxWidth": 4096,
    "maxHeight": 4096,
    "upscale": false
  },
  "vehicle360Config": {
    "frameCount": 36,
    "framePadding": 3,
    "frameFormat": "{vehicleId}/spin/{frame}.jpg",
    "preloadFrames": [0, 9, 18, 27],
    "defaultStartFrame": 0,
    "rotationDirection": "clockwise"
  }
}
