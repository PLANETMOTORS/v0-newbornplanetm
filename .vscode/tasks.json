{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CodeRabbit: Auth Status",
      "type": "shell",
      "command": "zsh",
      "args": [
        "-lc",
        "coderabbit auth status"
      ],
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "CodeRabbit: Review Uncommitted",
      "type": "shell",
      "command": "zsh",
      "args": [
        "-lc",
        "coderabbit --agent -t uncommitted"
      ],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "CodeRabbit: Review Plain",
      "type": "shell",
      "command": "zsh",
      "args": [
        "-lc",
        "coderabbit --plain -t uncommitted"
      ],
      "problemMatcher": []
    }
  ]
}
