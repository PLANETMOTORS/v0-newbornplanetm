{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pnpm install",
  "framework": "nextjs",
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "/api/sitemap"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/homenet-sync",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/drivee-sync",
      "schedule": "0 */6 * * *"
    }
  ]
}
